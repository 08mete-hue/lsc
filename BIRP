<script>

const checkboxes = document.querySelectorAll('input[type="checkbox"]');
const priceElement = document.getElementById('price');

let currentSlot = 1;

/* PREIS BERECHNEN */

function calculateTotal(){

    let total = 0;

    checkboxes.forEach(box => {

        if(box.checked){
            total += Number(box.value);
        }

    });

    priceElement.innerText = "$" + total.toLocaleString();

}

/* EVENTS */

checkboxes.forEach(box => {
    box.addEventListener('change', calculateTotal);
});

/* RESET */

function resetAll(){

    checkboxes.forEach(box => {
        box.checked = false;
    });

    calculateTotal();

}

/* BEZAHLEN */

function payBill(){

    let total = 0;

    checkboxes.forEach(box => {

        if(box.checked){
            total += Number(box.value);
        }

    });

    if(total <= 0){
        alert("Kein Betrag ausgewählt!");
        return;
    }

    document.getElementById("car" + currentSlot).innerText =
        "$" + total.toLocaleString();

    alert("Rechnung bezahlt: $" + total.toLocaleString());

    currentSlot++;

    if(currentSlot > 8){
        currentSlot = 1;
    }

    resetAll();

}

let calcDisplay = document.getElementById("calc-display");

function appendCalc(value) {
    calcDisplay.value += value;
}

function clearCalc() {
    calcDisplay.value = "";
}

function calculate() {
    try {
        calcDisplay.value = eval(calcDisplay.value);
    } catch {
        calcDisplay.value = "Fehler";
    }
}

/* VERTRÄGE */

let contracts = JSON.parse(localStorage.getItem("contracts")) || [];

/* SPEICHERN */

function saveContracts(){
    localStorage.setItem("contracts", JSON.stringify(contracts));
}

/* LADEN */

function loadContracts(){

    const table = document.getElementById("contractsTable");

    table.innerHTML = "";

    contracts.forEach((contract, index) => {

        const today = new Date();
        const expiry = new Date(contract.expiryDate);

        const expired = expiry < today;

        const row = document.createElement("tr");

        row.innerHTML = `
            <td>${contract.customer}</td>
            <td>${contract.contractDate}</td>
            <td>${contract.expiryDate}</td>
            <td class="${expired ? 'status-red' : 'status-green'}">
                ${expired ? 'Abgelaufen' : 'Aktiv'}
            </td>
            <td>
                <button class="edit-btn" onclick="editContract(${index})">
                    Bearbeiten
                </button>

                <button class="delete-btn" onclick="deleteContract(${index})">
                    Löschen
                </button>
            </td>
        `;

        table.appendChild(row);

    });

}

/* HINZUFÜGEN */

function addContract(){

    const customer = document.getElementById("customerName").value;
    const contractDate = document.getElementById("contractDate").value;
    const expiryDate = document.getElementById("expiryDate").value;

    if(!customer || !contractDate || !expiryDate){
        alert("Bitte alles ausfüllen!");
        return;
    }

    contracts.push({
        customer,
        contractDate,
        expiryDate
    });

    saveContracts();
    loadContracts();

    document.getElementById("customerName").value = "";
    document.getElementById("contractDate").value = "";
    document.getElementById("expiryDate").value = "";

}

function filterItems() {
    const input = document.getElementById("searchInput").value.toLowerCase();
    const items = document.querySelectorAll(".item");

    items.forEach(item => {
        const text = item.innerText.toLowerCase();

        if (text.includes(input)) {
            item.style.display = "flex";
        } else {
            item.style.display = "none";
        }
    });
}


/* LÖSCHEN */

function deleteContract(index){

    contracts.splice(index, 1);

    saveContracts();
    loadContracts();

}

/* BEARBEITEN */

function editContract(index){

    const contract = contracts[index];

    const newCustomer = prompt("Kundenname:", contract.customer);
    const newContractDate = prompt("Datum:", contract.contractDate);
    const newExpiryDate = prompt("Ablaufdatum:", contract.expiryDate);

    if(newCustomer && newContractDate && newExpiryDate){

        contracts[index] = {
            customer: newCustomer,
            contractDate: newContractDate,
            expiryDate: newExpiryDate
        };

        saveContracts();
        loadContracts();

    }

}

/* START */

loadContracts();

</script>

