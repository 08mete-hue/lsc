    height:55px;

    border-radius:50%;
    background:#0077ff;
    color:white;

    display:flex;
    align-items:center;
    justify-content:center;

    text-decoration:none;
    font-size:24px;

    box-shadow:0 4px 10px rgba(0,0,0,0.25);
    transition:0.3s;
}

.icon-button:hover{
    background:#005fcc;
    transform:scale(1.1);
}

/* BUTTONS */

.buttons{
    display:flex;
    flex-direction:column;
    gap:15px;
}

button{
    padding:22px;
