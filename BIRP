/* TABLET */

.tablet{
    width:1850px;
    background:linear-gradient(180deg,#08213a,#04111d);
    border:5px solid #0d0d0d;
    border-radius:20px;
    padding:20px;
    box-shadow:0 0 40px rgba(0,0,0,0.7);
}

/* HEADER */

.header{
    display:flex;
    justify-content:center;
    align-items:center;
    margin-bottom:20px;
}

.header img{
    width:450px;
    object-fit:contain;
}

/* MAIN */

.main{
    display:flex;
    gap:20px;
}

/* LEFT SIDE */

.left{
    width:560px;
    display:flex;
    flex-direction:column;
    gap:20px;
}

/* CAR IMAGE */

.car-preview{
    height:420px;
    border-radius:14px;
    overflow:hidden;
    border:3px solid #1d4f86;
    background:#010b14;
    display:flex;
    justify-content:center;
    align-items:center;
}

.car-preview img{
    width:100%;
